# vim: set ft=zsh expandtab:

sec2time() {
    zmodload zsh/datetime
    while (( $# > 0 )); do
        if [[ $1 =~ '([0-9]+)' ]]; then
            strftime "$match[1] => %c %Z" $match[1]
            TZ=GMT strftime "$match[1] => %c %Z" $match[1]
            print
        fi
        shift
    done
}
